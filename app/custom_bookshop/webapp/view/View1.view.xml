<mvc:View controllerName="custombookshop.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
    <Breadcrumbs id="_IDGenBreadcrumbs1" currentLocationText="Add New Item">
    <Link id="_IDGenLink" text="Master"></Link>
    </Breadcrumbs>
   <HBox id="_IDGenHBox" >
   <VBox id="_IDGenVBox" />
   </HBox>

    <HBox id="_IDGenHBox1" >
    <VBox id="_IDGenVBox1" >
    <Label id="_IDGenLabel1" text="Title"></Label>
    <Input id="inputTitle" placeholder="Enter Your Title" ></Input>
   </VBox>
   <VBox id="_IDGenVBox2" >
      <Label id="_IDGenLabel2" text="Author"></Label>
    <Input id="inputAuthor" placeholder="Enter Your Author" ></Input>
</VBox>
   <VBox id="_IDGenVBox3" >
      <Label id="_IDGenLabel3" text="Price"></Label>
    <Input id="inputPrice" placeholder="Enter Your Price" ></Input>
    </VBox>
    </HBox>


      <HBox id="_IDGenHBox2" >
    <VBox id="_IDGenVBox4" >
    <Label id="_IDGenLabel4" text="Stock"></Label>
    <Input id="inputStock" placeholder="Enter Your Stock" ></Input>
   </VBox>
   <VBox id="_IDGenVBox5" >
      <Label id="_IDGenLabel5" text="Location"></Label>
    <Input id="inputLocation" placeholder="Enter Your Location" ></Input>
</VBox>
   <VBox id="_IDGenVBox6" >
      <Label id="_IDGenLabel6" text="Genre"></Label>
    <Input id="inputGenre" placeholder="Enter Your Genre" ></Input>
    </VBox>
    </HBox>
    <HBox id="_IDGenHBox3" >
    <VBox id="_IDGenVBox7" >
    <Button id="_IDGenButton1" text="Submit" press="onSubmit"></Button>
    </VBox>
    </HBox>

    <Table id="_IDGenTable" items="{/Books}">
    <columns>
    <Column id="_IDGenColumn" >
    <Text id="_IDGenText7" text="Title"></Text>
    </Column>
    <Column id="_IDGenColumn1" >
    <Text id="_IDGenText8" text="Author"></Text>
    </Column>
    <Column id="_IDGenColumn2" >
    <Text id="_IDGenText9" text="Price"></Text>
    </Column>
    <Column id="_IDGenColumn3" >
    <Text id="_IDGenText10" text="Stock"></Text>
    </Column>
    <Column id="_IDGenColumn4">
    <Text id="_IDGenText11" text="Location"></Text>
    </Column>
    <Column id="_IDGenColumn5" >
    <Text id="_IDGenText12" text="Genre"></Text>
    </Column>
    </columns>
    <items>
    <ColumnListItem id="_IDGenColumnListItem" >
    <cells>
    <Text id="_IDGenText1" text="{title}"></Text>
    <Text id="_IDGenText2" text="{author}"></Text>
    <Text id="_IDGenText3" text="{price}"></Text>
    <Text id="_IDGenText4" text="{stock}"></Text>
    <Text id="_IDGenText5" text="{location}"></Text>
    <Text id="_IDGenText6" text="{genre}"></Text>
    </cells>
    </ColumnListItem>
    </items>
    
    </Table>
    </Page>
</mvc:View>